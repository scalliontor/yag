APP_BASE_URL=http://localhost:8000
DATABASE_URL=data/yag.sqlite

# Google OAuth. Prefer GOOGLE_CLIENT_SECRET_FILE for local POC.
GOOGLE_CLIENT_SECRET_FILE=client_secret.json
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OpenAI-compatible API used by Gemma.
# For the provided Xiaomi MiMo token-plan API keys (`tp-...`), use this base URL.
OPENAI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
OPENAI_API_KEY=replace_me
LLM_MODEL=mimo-v2.5

SCHEDULER_ENABLED=true
